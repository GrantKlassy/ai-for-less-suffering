---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const pathname = Astro.url.pathname;
const navItems = [
  { href: "/analyses/", label: "analyses" },
  { href: "/camps/", label: "camps" },
  { href: "/claims/", label: "claims" },
  { href: "/interventions/", label: "interventions" },
  { href: "/sources/", label: "sources" },
  { href: "/layers/", label: "layers" },
];
const isActive = (href: string) =>
  pathname === href || pathname.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="bg-zinc-950 font-mono text-zinc-100">
    <div class="mx-auto flex min-h-screen max-w-3xl flex-col px-6 py-10">
      <header class="mb-10 border-b border-zinc-800 pb-4">
        <a
          href="/"
          class="text-sm text-zinc-400 hover:text-zinc-100"
          aria-label="home">ai-for-less-suffering.com</a
        >
        <nav class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-zinc-500">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class:list={[
                  "hover:text-zinc-200",
                  isActive(item.href) &&
                    "text-zinc-100 underline decoration-zinc-500 underline-offset-4",
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>
      <main class="flex-1">
        <slot />
      </main>
      <footer class="mt-16 border-t border-zinc-800 pt-4 text-xs text-zinc-500">
        <a href="/canary/" class="hover:text-zinc-300">canary</a>
        <span class="mx-2 text-zinc-700">·</span>
        <a
          href="https://github.com/GrantKlassy/ai-for-less-suffering"
          class="hover:text-zinc-300">source</a
        >
      </footer>
    </div>
  </body>
</html>
