---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="bg-zinc-950 font-mono text-zinc-100">
    <div class="mx-auto flex min-h-screen max-w-3xl flex-col px-6 py-10">
      <header class="mb-10 border-b border-zinc-800 pb-4">
        <a
          href="/"
          class="text-sm text-zinc-400 hover:text-zinc-100"
          aria-label="home">ai-for-less-suffering.com</a
        >
        <nav class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-zinc-500">
          <a href="/analyses/" class="hover:text-zinc-200">analyses</a>
          <a href="/camps/" class="hover:text-zinc-200">camps</a>
          <a href="/claims/" class="hover:text-zinc-200">claims</a>
          <a href="/interventions/" class="hover:text-zinc-200">interventions</a
          >
          <a href="/sources/" class="hover:text-zinc-200">sources</a>
          <a href="/layers/" class="hover:text-zinc-200">layers</a>
        </nav>
      </header>
      <main class="flex-1">
        <slot />
      </main>
      <footer class="mt-16 border-t border-zinc-800 pt-4 text-xs text-zinc-500">
        <a href="/canary/" class="hover:text-zinc-300">canary</a>
        <span class="mx-2 text-zinc-700">·</span>
        <a
          href="https://github.com/GrantKlassy/ai-for-less-suffering"
          class="hover:text-zinc-300">source</a
        >
      </footer>
    </div>
  </body>
</html>
