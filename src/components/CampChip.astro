---
// Compact camp link for coalition strips. Wraps NodeRef with a slightly
// heavier background so a row of chips reads as a cohesive set (palantir +
// anthropic + operator) rather than as disjoint links.

import NodeRef from "./NodeRef.astro";

interface Props {
  id: string;
  class?: string;
}

const { id, class: className = "" } = Astro.props;
---

<span
  class:list={[
    "inline-flex rounded border border-zinc-800 bg-zinc-900/60 px-2 py-1 text-xs",
    className,
  ]}
>
  <NodeRef id={id} />
</span>
