---
// Renders a friction_scores, harm_scores, or suffering_reduction_scores map as
// a labeled set of bars. Polarity is shared across all three: 1 = best outcome
// (no friction / no harm / max suffering reduction), 0 = worst (blocked / max
// harm / no reduction). The color runs cold-left → warm-right so the bad end
// is visually short/cool and the good end is long/warm, regardless of which
// layer kind is scored. Keep the polarity convention synchronized with
// engine/afls/schema/interventions.py and suffering_layers.py.

import NodeRef from "./NodeRef.astro";

interface Props {
  kind: "friction" | "harm" | "suffering";
  scores: Record<string, number>;
  class?: string;
}

const { kind, scores, class: className = "" } = Astro.props;
const entries = Object.entries(scores).sort(([a], [b]) => a.localeCompare(b));

const accentFill =
  kind === "friction"
    ? "from-orange-800 via-amber-600 to-emerald-500"
    : kind === "harm"
      ? "from-rose-800 via-amber-600 to-emerald-500"
      : "from-zinc-800 via-emerald-700 to-emerald-400";
---

<div class:list={["space-y-1.5", className]}>
  {
    entries.length === 0 && (
      <p class="text-xs text-zinc-600">No {kind} scores.</p>
    )
  }
  {
    entries.map(([id, value]) => {
      const pct = Math.max(0, Math.min(1, value)) * 100;
      return (
        <div class="flex items-center gap-2 text-xs">
          <div class="w-40 shrink-0 truncate">
            <NodeRef id={id} showKind={false} />
          </div>
          <div class="relative h-1.5 flex-1 overflow-hidden rounded-full bg-zinc-900">
            <div
              class:list={[
                "absolute inset-y-0 left-0 bg-gradient-to-r",
                accentFill,
              ]}
              style={`width: ${pct}%`}
            />
          </div>
          <span class="w-10 shrink-0 text-right font-mono text-zinc-400">
            {value.toFixed(2)}
          </span>
        </div>
      );
    })
  }
</div>
