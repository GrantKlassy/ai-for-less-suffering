---
// Small colored pill naming the axiom family a normative claim sits in.
// Palette chosen to keep consequentialist/eacc/ea_80k visually distinct since
// those are the frames with the most overlap in this repo's camps.

interface Props {
  family: string;
  detail?: string;
  class?: string;
}

const { family, detail, class: className = "" } = Astro.props;

const styles: Record<string, string> = {
  kantian: "bg-slate-900 text-slate-300 ring-slate-700",
  capabilities: "bg-teal-950 text-teal-300 ring-teal-800",
  theological: "bg-amber-950 text-amber-300 ring-amber-800",
  consequentialist: "bg-emerald-950 text-emerald-300 ring-emerald-800",
  e_acc: "bg-rose-950 text-rose-300 ring-rose-800",
  ea_80k: "bg-sky-950 text-sky-300 ring-sky-800",
  poker_ev: "bg-fuchsia-950 text-fuchsia-300 ring-fuchsia-800",
  other: "bg-zinc-900 text-zinc-400 ring-zinc-700",
};

const cls = styles[family] ?? styles.other;
---

<span
  class:list={[
    "inline-flex items-center rounded-sm px-1.5 py-0.5 text-[10px] font-semibold tracking-wide uppercase ring-1 ring-inset",
    cls,
    className,
  ]}
  title={detail || undefined}
>
  {family.replace(/_/g, " ")}
</span>
