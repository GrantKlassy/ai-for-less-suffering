---
// One side of a steelman --- FOR or AGAINST. Heading = AxiomTag, body = case
// prose, footer = two NodeRef lists (normative anchors + descriptive
// evidence). The parent SteelmanView places two of these in md:grid-cols-2.

import NodeRef from "../NodeRef.astro";
import AxiomTag from "../AxiomTag.astro";
import type { SteelmanFrame } from "../../lib/analysis";

interface Props {
  frame: SteelmanFrame;
  stance: "for" | "against";
}

const { frame, stance } = Astro.props;
const accent = stance === "for" ? "border-emerald-900" : "border-rose-900";
---

<div class:list={["rounded border p-4", accent]}>
  <div class="mb-3">
    <AxiomTag family={frame.axiom_family} />
  </div>
  <p class="mb-4 text-sm whitespace-pre-line text-zinc-200">{frame.case}</p>
  {
    frame.normative_claim_ids.length > 0 && (
      <div class="mb-3 text-xs">
        <div class="mb-1 text-zinc-500">Normative anchors</div>
        <ul class="space-y-1">
          {frame.normative_claim_ids.map((id) => (
            <li>
              <NodeRef id={id} />
            </li>
          ))}
        </ul>
      </div>
    )
  }
  {
    frame.descriptive_claim_ids.length > 0 && (
      <div class="text-xs">
        <div class="mb-1 text-zinc-500">Descriptive evidence</div>
        <ul class="space-y-1">
          {frame.descriptive_claim_ids.map((id) => (
            <li>
              <NodeRef id={id} />
            </li>
          ))}
        </ul>
      </div>
    )
  }
</div>
