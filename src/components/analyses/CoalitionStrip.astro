---
// Horizontal row of camp chips shown at the top of a palantir or leverage
// analysis, so the set of camps under analysis is visible before anything
// else. Wraps on narrow widths.

import CampChip from "../CampChip.astro";

interface Props {
  camps: string[];
  label?: string;
  class?: string;
}

const { camps, label = "Camps in scope", class: className = "" } = Astro.props;
---

<section class:list={["mb-8", className]}>
  <h2 class="mb-2 text-xs font-semibold tracking-wide text-zinc-500 uppercase">
    {label}
  </h2>
  <div class="flex flex-wrap gap-2">
    {camps.map((id) => <CampChip id={id} />)}
  </div>
</section>
