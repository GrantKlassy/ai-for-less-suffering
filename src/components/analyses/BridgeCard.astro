---
// "From camp → translation → To camp" bridge card for palantir analyses.
// Caveats list what the bridge does NOT translate --- the honest edge.

import NodeRef from "../NodeRef.astro";
import type { Bridge } from "../../lib/analysis";

interface Props {
  bridge: Bridge;
}

const { bridge } = Astro.props;
---

<div class="rounded border border-zinc-800 p-4">
  <div class="mb-2 flex flex-wrap items-baseline gap-x-2 text-sm">
    <NodeRef id={bridge.from_camp} />
    <span class="text-zinc-500">→</span>
    <NodeRef id={bridge.to_camp} />
  </div>
  <p class="mb-3 text-sm text-zinc-300">{bridge.translation}</p>
  {
    bridge.caveats.length > 0 && (
      <div>
        <div class="mb-1 text-xs text-zinc-500">Does not translate:</div>
        <ul class="list-inside list-disc space-y-1 text-xs text-zinc-400">
          {bridge.caveats.map((caveat) => (
            <li>{caveat}</li>
          ))}
        </ul>
      </div>
    )
  }
</div>
