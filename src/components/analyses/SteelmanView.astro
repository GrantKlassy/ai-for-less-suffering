---
// Steelman render. Shape is load-bearing: operator tension goes above the
// columns (what the analyst is actually wrestling with), conceded descriptive
// goes between tension and columns (the shared ground both sides stand on),
// FOR and AGAINST live side-by-side so the frame-divergence is visible
// without scrolling. This order lets a cold reader restate the three
// manifesto acceptance items: (a) what both sides concede, (b) which axiom
// family makes one side find it compelling, (c) where the bridge breaks.

import { getEntry } from "astro:content";
import NodeRef from "../NodeRef.astro";
import SteelmanFrame from "./SteelmanFrame.astro";
import type { SteelmanAnalysis } from "../../lib/analysis";

interface Props {
  analysis: SteelmanAnalysis;
}

const { analysis } = Astro.props;

const concededText: Record<string, string> = {};
for (const id of analysis.conceded_descriptive) {
  const entry = await getEntry("descriptiveClaims", id);
  if (entry) concededText[id] = entry.data.text;
}
---

<section class="mb-8">
  <h2 class="mb-2 text-xs font-semibold tracking-wide text-zinc-500 uppercase">
    Target intervention
  </h2>
  <div class="rounded border border-zinc-800 p-4 text-sm">
    <p class="mb-2 text-zinc-100">{analysis.target_intervention_text}</p>
    <NodeRef id={analysis.target_intervention_id} />
  </div>
</section>

<section class="mb-8">
  <h2 class="mb-2 text-xs font-semibold tracking-wide text-zinc-500 uppercase">
    Operator tension
  </h2>
  <blockquote
    class="rounded border border-amber-900/60 bg-amber-950/20 p-4 text-sm text-amber-100 italic"
  >
    {analysis.operator_tension}
  </blockquote>
</section>

{
  analysis.conceded_descriptive.length > 0 && (
    <section class="mb-8">
      <h2 class="mb-2 text-xs font-semibold tracking-wide text-zinc-500 uppercase">
        Both sides cite
      </h2>
      <ul class="grid gap-2 md:grid-cols-2">
        {analysis.conceded_descriptive.map((id) => (
          <li class="rounded border border-zinc-800 bg-zinc-950/50 p-3 text-xs">
            {concededText[id] && (
              <p class="mb-1 text-sm text-zinc-100">{concededText[id]}</p>
            )}
            <NodeRef id={id} />
          </li>
        ))}
      </ul>
    </section>
  )
}

<section class="mb-10">
  <div class="mb-3 grid gap-4 md:grid-cols-2">
    <h2 class="border-b border-emerald-900 pb-1 text-lg text-emerald-300">
      Case FOR
    </h2>
    <h2 class="border-b border-rose-900 pb-1 text-lg text-rose-300">
      Case AGAINST
    </h2>
  </div>
  <div class="grid gap-4 md:grid-cols-2">
    <div class="space-y-4">
      {
        analysis.case_for.length === 0 ? (
          <p class="text-sm text-zinc-500">No FOR frames generated.</p>
        ) : (
          analysis.case_for.map((frame) => (
            <SteelmanFrame frame={frame} stance="for" />
          ))
        )
      }
    </div>
    <div class="space-y-4">
      {
        analysis.case_against.length === 0 ? (
          <p class="text-sm text-zinc-500">No AGAINST frames generated.</p>
        ) : (
          analysis.case_against.map((frame) => (
            <SteelmanFrame frame={frame} stance="against" />
          ))
        )
      }
    </div>
  </div>
</section>
