---
// Shared across all analysis kinds. Renders contested_claims as claim cards
// with three vertical stance tracks (supports / contradicts / qualifies).
// Source titles link through NodeRef to their detail pages.

import NodeRef from "../NodeRef.astro";
import ConfidenceBar from "../ConfidenceBar.astro";
import type { ContestedClaim } from "../../lib/analysis";

interface Props {
  claims: ContestedClaim[];
}

const { claims } = Astro.props;

const trackColor: Record<"supports" | "contradicts" | "qualifies", string> = {
  supports: "text-emerald-400",
  contradicts: "text-rose-400",
  qualifies: "text-amber-400",
};
---

<section class="mb-10">
  <h2 class="mb-3 border-b border-zinc-800 pb-1 text-lg text-zinc-200">
    Contested claims
  </h2>
  {
    claims.length === 0 ? (
      <p class="text-sm text-zinc-500">
        No claim carries both supporting and contradicting warrants. Absence is
        not proof of consensus --- the graph may only have collected one side.
      </p>
    ) : (
      <div class="space-y-6">
        {claims.map((claim) => (
          <div class="rounded border border-zinc-800 p-4">
            <p class="mb-2 text-sm text-zinc-100">{claim.claim_text}</p>
            <div class="mb-3">
              <NodeRef id={claim.claim_id} />
            </div>
            {(["supports", "contradicts", "qualifies"] as const).map(
              (stance) =>
                claim[stance].length > 0 ? (
                  <div class="mb-3">
                    <div
                      class:list={[
                        "mb-1 text-xs font-semibold tracking-wide uppercase",
                        trackColor[stance],
                      ]}
                    >
                      {stance}
                    </div>
                    <ul class="space-y-2 text-xs text-zinc-300">
                      {claim[stance].map((w) => (
                        <li class="rounded border border-zinc-900 p-2">
                          <div class="mb-1 flex flex-wrap items-baseline justify-between gap-x-2">
                            <NodeRef id={w.source_id} label={w.source_title} />
                            <span class="font-mono text-zinc-500">
                              {w.method_tag}
                            </span>
                          </div>
                          <ConfidenceBar value={w.weight} label="weight" />
                          {w.locator && (
                            <p class="mt-1 text-zinc-500">
                              <span class="text-zinc-600">locator:</span>{" "}
                              {w.locator}
                            </p>
                          )}
                        </li>
                      ))}
                    </ul>
                  </div>
                ) : null,
            )}
          </div>
        ))}
      </div>
    )
  }
</section>
