---
// Palantir blindspot: a camp flagged against a prior set, with reasoning for
// why that prior set may not see what it sees.

import NodeRef from "../NodeRef.astro";
import type { BlindSpot } from "../../lib/analysis";

interface Props {
  blindspot: BlindSpot;
}

const { blindspot } = Astro.props;
---

<li class="rounded border border-zinc-800 p-3">
  <div class="mb-1 flex flex-wrap items-baseline gap-x-2 text-xs">
    <span class="text-zinc-500">Against</span>
    <span class="font-mono text-zinc-400">{blindspot.against_prior_set}</span>
    <span class="text-zinc-500">· flags</span>
    <NodeRef id={blindspot.flagged_camp_id} />
  </div>
  <p class="text-sm text-zinc-200">{blindspot.reasoning}</p>
</li>
