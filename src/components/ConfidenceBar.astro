---
// 0–1 horizontal bar used for claim.confidence, evidence.weight, and
// intervention.leverage_score. The color gradient is fixed (cool low → warm
// high) not semantic --- the value itself is what matters, not a stance.

interface Props {
  value: number;
  label?: string;
  class?: string;
}

const { value, label, class: className = "" } = Astro.props;
const pct = Math.max(0, Math.min(1, value)) * 100;
const display = value.toFixed(2);
---

<div class:list={["flex items-center gap-2 text-xs", className]}>
  {label && <span class="w-24 shrink-0 text-zinc-500">{label}</span>}
  <div class="relative h-1.5 flex-1 overflow-hidden rounded-full bg-zinc-900">
    <div
      class="absolute inset-y-0 left-0 bg-gradient-to-r from-sky-700 via-teal-600 to-emerald-500"
      style={`width: ${pct}%`}
    >
    </div>
  </div>
  <span class="w-10 shrink-0 text-right font-mono text-zinc-400">{display}</span
  >
</div>
