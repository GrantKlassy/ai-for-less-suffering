---
// Stance pill for the operator's position on an intervention. Colors mirror
// the semantic weight of each stance --- priority is brightest, oppose is
// rose, under_consideration is the muted zinc that signals "not yet decided".

import type { Stance } from "../../lib/positions";

interface Props {
  stance: Stance;
}

const { stance } = Astro.props;

const label: Record<Stance, string> = {
  priority: "priority",
  qualified_support: "qualified support",
  skeptical: "skeptical",
  oppose: "oppose",
  under_consideration: "under consideration",
};

const classes: Record<Stance, string> = {
  priority: "bg-emerald-950 text-emerald-300 border-emerald-800",
  qualified_support: "bg-amber-950 text-amber-300 border-amber-800",
  skeptical: "bg-zinc-900 text-zinc-400 border-zinc-700",
  oppose: "bg-rose-950 text-rose-300 border-rose-800",
  under_consideration: "bg-zinc-900 text-zinc-500 border-zinc-800",
};
---

<span
  class:list={[
    "inline-flex items-center rounded border px-2 py-0.5 text-[11px] tracking-wide uppercase",
    classes[stance],
  ]}>{label[stance]}</span
>
