---
import { loadGraphData } from "../../lib/graph-data";

const data = await loadGraphData();
const payload = JSON.stringify(data);
---

<figure
  class="my-6 overflow-hidden rounded border border-zinc-800 bg-zinc-950/80"
>
  <div
    id="afls-graph"
    class="relative h-[520px] w-full sm:h-[620px]"
    aria-label="typed reasoning graph: camps, claims, interventions"
  >
  </div>
  <figcaption
    class="flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-zinc-800 bg-zinc-900/40 px-3 py-2 text-[11px] text-zinc-500"
  >
    <span>drag · scroll to zoom · click a node to open it</span>
    <span class="ml-auto text-zinc-600"
      >{data.nodes.length} nodes · {data.edges.length} edges</span
    >
  </figcaption>
</figure>

<script
  is:inline
  type="application/json"
  id="afls-graph-data"
  set:html={payload}
/>

<noscript>
  <p class="text-xs text-zinc-500">
    interactive graph requires JS. walk the graph via
    <a href="/camps/" class="text-zinc-300 underline-offset-2 hover:underline">
      camps
    </a>, <a
      href="/claims/"
      class="text-zinc-300 underline-offset-2 hover:underline">claims</a
    >, <a
      href="/interventions/"
      class="text-zinc-300 underline-offset-2 hover:underline">interventions</a
    >.
  </p>
</noscript>

<script>
  import type { EventObject } from "cytoscape";
  import { initGraph, highlightKind } from "./GraphCanvas.ts";
  import type { NodeKind } from "../../lib/graph";

  // Legend pills carry `data-kind="<NodeKind>"`. Hovering a pill fades every
  // graph node whose kind differs; leaving restores. Reverse direction: hovering
  // a graph node adds a ring to the matching pill so the pairing is symmetric.
  const mount = () => {
    const cy = initGraph("afls-graph", "afls-graph-data");
    if (!cy) return;

    const pills = document.querySelectorAll<HTMLElement>("[data-kind]");
    const pillByKind = new Map<string, HTMLElement>();
    for (const pill of pills) {
      const kind = pill.dataset.kind;
      if (!kind) continue;
      pillByKind.set(kind, pill);
      pill.addEventListener("mouseenter", () => {
        highlightKind(cy, kind as NodeKind);
      });
      pill.addEventListener("mouseleave", () => {
        highlightKind(cy, null);
      });
    }

    cy.on("mouseover", "node", (event: EventObject) => {
      const kind = event.target.data("kind") as string | undefined;
      if (!kind) return;
      pillByKind.get(kind)?.classList.add("ring-1", "ring-zinc-100");
    });
    cy.on("mouseout", "node", (event: EventObject) => {
      const kind = event.target.data("kind") as string | undefined;
      if (!kind) return;
      pillByKind.get(kind)?.classList.remove("ring-1", "ring-zinc-100");
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", mount);
  } else {
    mount();
  }
</script>
