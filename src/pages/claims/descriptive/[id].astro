---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import NodeRef from "../../../components/NodeRef.astro";
import ConfidenceBar from "../../../components/ConfidenceBar.astro";
import {
  analysesReferencing,
  campsHoldingDescriptive,
  evidenceForClaim,
} from "../../../lib/graph";

export async function getStaticPaths() {
  const claims = await getCollection("descriptiveClaims");
  return claims.map((c) => ({ params: { id: c.id }, props: { claim: c } }));
}

type Claim = Awaited<
  ReturnType<typeof getCollection<"descriptiveClaims">>
>[number];
interface Props {
  claim: Claim;
}

const { claim } = Astro.props as Props;
const evidence = await evidenceForClaim(claim.id);
const camps = await campsHoldingDescriptive(claim.id);
const referencedBy = analysesReferencing(claim.id);

const evidenceByStance = {
  supports: evidence.filter((e) => e.data.supports === "support"),
  contradicts: evidence.filter((e) => e.data.supports === "contradict"),
  qualifies: evidence.filter((e) => e.data.supports === "qualify"),
};
const stanceColor: Record<string, string> = {
  supports: "text-emerald-300",
  contradicts: "text-rose-300",
  qualifies: "text-amber-300",
};
---

<Base title="Descriptive claim --- ai-for-less-suffering">
  <p class="mb-2 text-xs text-zinc-500">
    <a href="/claims/" class="hover:text-zinc-300">← all claims</a>
  </p>
  <p class="mb-2 font-mono text-xs text-sky-400">descriptive claim</p>
  <h1 class="mb-4 text-xl leading-relaxed text-zinc-100">{claim.data.text}</h1>
  <p class="mb-6 font-mono text-xs text-zinc-500">{claim.data.id}</p>

  <section class="mb-8">
    <ConfidenceBar value={claim.data.confidence} label="confidence" />
  </section>

  {
    evidence.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-3 text-sm text-zinc-400">Evidence ({evidence.length})</h2>
        {(["supports", "contradicts", "qualifies"] as const).map((stance) =>
          evidenceByStance[stance].length > 0 ? (
            <div class="mb-4">
              <h3
                class:list={[
                  "mb-2 text-xs font-semibold tracking-wide uppercase",
                  stanceColor[stance],
                ]}
              >
                {stance} ({evidenceByStance[stance].length})
              </h3>
              <ul class="space-y-3">
                {evidenceByStance[stance].map((e) => (
                  <li class="rounded border border-zinc-800 p-3 text-xs">
                    <div class="mb-1 flex items-center justify-between">
                      <NodeRef id={e.data.source_id.id} />
                      <span class="font-mono text-zinc-500">
                        {e.data.method_tag}
                      </span>
                    </div>
                    <ConfidenceBar
                      value={e.data.weight}
                      label="weight"
                      class="mb-2"
                    />
                    {e.data.locator && (
                      <p class="text-zinc-500">
                        <span class="text-zinc-600">locator:</span>{" "}
                        {e.data.locator}
                      </p>
                    )}
                    {e.data.quote && (
                      <blockquote class="mt-1 border-l-2 border-zinc-700 pl-3 text-zinc-300">
                        “{e.data.quote}”
                      </blockquote>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ) : null,
        )}
      </section>
    )
  }

  {
    camps.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Camps holding this claim ({camps.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {camps.map((c) => (
            <li>
              <NodeRef id={c.id} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    referencedBy.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Analyses citing this claim ({referencedBy.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {referencedBy.map(({ id }) => (
            <li>
              <a
                href={`/analyses/${id}/`}
                class="font-mono text-xs text-zinc-300 hover:text-zinc-100 hover:underline"
              >
                {id}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Base>
