---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import NodeRef from "../../../components/NodeRef.astro";
import { analysesReferencing, campsHoldingNormative } from "../../../lib/graph";

export async function getStaticPaths() {
  const claims = await getCollection("normativeClaims");
  return claims.map((c) => ({ params: { id: c.id }, props: { claim: c } }));
}

type Claim = Awaited<
  ReturnType<typeof getCollection<"normativeClaims">>
>[number];
interface Props {
  claim: Claim;
}

const { claim } = Astro.props as Props;
const camps = await campsHoldingNormative(claim.id);
const referencedBy = analysesReferencing(claim.id);
---

<Base title="Normative claim --- ai-for-less-suffering">
  <p class="mb-2 text-xs text-zinc-500">
    <a href="/claims/" class="hover:text-zinc-300">← all claims</a>
  </p>
  <p class="mb-2 font-mono text-xs text-violet-400">normative claim</p>
  <h1 class="mb-4 text-xl leading-relaxed text-zinc-100">{claim.data.text}</h1>

  <div class="mb-6">
    <span class="font-mono text-xs text-zinc-500">{claim.data.id}</span>
  </div>

  {
    camps.length > 0 ? (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Camps holding this claim ({camps.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {camps.map((c) => (
            <li>
              <NodeRef id={c.id} />
            </li>
          ))}
        </ul>
      </section>
    ) : (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">Camps holding this claim</h2>
        <p class="text-sm text-zinc-600">
          No camp in the graph holds this claim yet.
        </p>
      </section>
    )
  }

  {
    referencedBy.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Analyses citing this claim ({referencedBy.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {referencedBy.map(({ id }) => (
            <li>
              <a
                href={`/analyses/${id}/`}
                class="font-mono text-xs text-zinc-300 hover:text-zinc-100 hover:underline"
              >
                {id}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Base>
