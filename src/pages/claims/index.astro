---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import CampChip from "../../components/CampChip.astro";

const descriptive = (await getCollection("descriptiveClaims")).sort((a, b) =>
  a.data.text.localeCompare(b.data.text),
);
const normative = (await getCollection("normativeClaims")).sort((a, b) =>
  a.data.text.localeCompare(b.data.text),
);

const camps = await getCollection("camps");
const holdersByNorm = new Map<string, string[]>();
for (const camp of camps) {
  for (const ref of camp.data.held_normative) {
    const list = holdersByNorm.get(ref.id) ?? [];
    list.push(camp.id);
    holdersByNorm.set(ref.id, list);
  }
}
---

<Base title="Claims --- ai-for-less-suffering">
  <h1 class="mb-2 text-2xl text-zinc-100">🪧 Claims</h1>
  <p class="mb-8 text-sm text-zinc-400">
    Descriptive claims say what <em>is</em>. Normative claims say what
    <em>ought</em> to be. Camps can share descriptive claims; they almost never share
    normative ones. Separating them is the whole point.
  </p>

  <section class="mb-10">
    <h2 class="mb-4 flex items-baseline gap-2 text-lg text-sky-300">
      <span
        class="inline-flex h-4 min-w-4 shrink-0 items-center justify-center self-center rounded-sm bg-sky-950 px-1 font-mono text-[10px] font-semibold text-sky-300"
        aria-hidden="true">CD</span
      >
      ✅ Descriptive ({descriptive.length})
    </h2>
    <ul class="space-y-2">
      {
        descriptive.map((c) => (
          <li class="rounded border border-zinc-800 p-3 hover:border-zinc-600">
            <a
              href={`/claims/descriptive/${c.id}/`}
              class="block text-sm text-zinc-200"
            >
              <p>{c.data.text}</p>
              <p class="mt-1 flex items-center justify-between text-xs">
                <span class="font-mono text-zinc-500">{c.data.id}</span>
                <span class="text-zinc-500">
                  confidence {c.data.confidence.toFixed(2)}
                </span>
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mb-10">
    <h2 class="mb-4 flex items-baseline gap-2 text-lg text-violet-300">
      <span
        class="inline-flex h-4 min-w-4 shrink-0 items-center justify-center self-center rounded-sm bg-violet-950 px-1 font-mono text-[10px] font-semibold text-violet-300"
        aria-hidden="true">CN</span
      >
      💭 Normative ({normative.length})
    </h2>
    <ul class="space-y-2">
      {
        normative.map((c) => {
          const holders = holdersByNorm.get(c.id) ?? [];
          return (
            <li class="rounded border border-zinc-800 p-3 hover:border-zinc-600">
              <a
                href={`/claims/normative/${c.id}/`}
                class="block text-sm text-zinc-200"
              >
                <p>{c.data.text}</p>
                <p class="mt-1 font-mono text-xs text-zinc-500">{c.data.id}</p>
              </a>
              <div class="mt-2 flex flex-wrap items-center gap-2 text-xs">
                {holders.length > 0 ? (
                  holders.map((id) => <CampChip id={id} />)
                ) : (
                  <span class="text-zinc-600">(no camp holds this yet)</span>
                )}
              </div>
            </li>
          );
        })
      }
    </ul>
  </section>
</Base>
