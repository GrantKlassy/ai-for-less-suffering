---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import ConfidenceBar from "../../components/ConfidenceBar.astro";
import ScoreMatrix from "../../components/ScoreMatrix.astro";
import { analysesReferencing } from "../../lib/graph";

export async function getStaticPaths() {
  const interventions = await getCollection("interventions");
  return interventions.map((i) => ({
    params: { id: i.id },
    props: { intervention: i },
  }));
}

type Intervention = Awaited<
  ReturnType<typeof getCollection<"interventions">>
>[number];
interface Props {
  intervention: Intervention;
}

const { intervention } = Astro.props as Props;
const referencedBy = analysesReferencing(intervention.id);
---

<Base title={`${intervention.data.id} --- intervention`}>
  <p class="mb-2 text-xs text-zinc-500">
    <a href="/interventions/" class="hover:text-zinc-300">← all interventions</a
    >
  </p>
  <p class="mb-2 font-mono text-xs text-emerald-400">
    intervention · {intervention.data.action_kind}
  </p>
  <h1 class="mb-4 text-xl leading-relaxed text-zinc-100">
    {intervention.data.text}
  </h1>
  <p class="mb-6 font-mono text-xs text-zinc-500">{intervention.data.id}</p>

  <section class="mb-6 space-y-2">
    <ConfidenceBar value={intervention.data.leverage_score} label="leverage" />
    {
      intervention.data.cost_estimate && (
        <p class="text-xs text-zinc-400">
          <span class="text-zinc-600">cost:</span>{" "}
          {intervention.data.cost_estimate}
        </p>
      )
    }
  </section>

  <section class="mb-8">
    <h2 class="mb-2 text-sm text-orange-300">
      Friction (1 = unblocked · 0 = blocked)
    </h2>
    <ScoreMatrix kind="friction" scores={intervention.data.friction_scores} />
  </section>

  <section class="mb-8">
    <h2 class="mb-2 text-sm text-rose-300">
      Harm (1 = no harm · 0 = maximum harm)
    </h2>
    <ScoreMatrix kind="harm" scores={intervention.data.harm_scores} />
  </section>

  <section class="mb-8">
    <h2 class="mb-2 text-sm text-emerald-300">
      Suffering reduction (1 = maximum reduction · 0 = no reduction)
    </h2>
    <p class="mb-2 max-w-prose text-xs text-zinc-500">
      The numerator in -suffering EV. Operator-scored expected reduction across
      each suffering layer. Without this, the tool only scores the costs of
      deploying; with it, leverage × friction × harm × suffering composes into a
      real −suffering signal.
    </p>
    <ScoreMatrix
      kind="suffering"
      scores={intervention.data.suffering_reduction_scores}
    />
  </section>

  {
    referencedBy.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Analyses featuring this intervention ({referencedBy.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {referencedBy.map(({ id }) => (
            <li>
              <a
                href={`/analyses/${id}/`}
                class="font-mono text-xs text-zinc-300 hover:text-zinc-100 hover:underline"
              >
                {id}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Base>
