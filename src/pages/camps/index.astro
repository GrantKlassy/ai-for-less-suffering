---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const camps = await getCollection("camps");
camps.sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<Base title="Camps --- ai-for-less-suffering">
  <h1 class="mb-2 text-2xl text-zinc-100">Camps</h1>
  <p class="mb-8 text-sm text-zinc-400">
    Coalition-logic units. Each holds descriptive claims (shared across camps in
    convergence) and normative claims (divergent across camps by axiom family).
    Palantir and Anthropic can agree on a fact about compute without agreeing on
    why it matters.
  </p>
  <ul class="space-y-3">
    {
      camps.map((c) => (
        <li class="rounded border border-zinc-800 p-4 hover:border-zinc-600">
          <a href={`/camps/${c.id}/`} class="block">
            <div class="flex items-baseline justify-between">
              <h2 class="text-zinc-100">{c.data.name}</h2>
              <span class="font-mono text-xs text-zinc-500">{c.data.id}</span>
            </div>
            <p class="mt-1 text-sm text-zinc-400">{c.data.summary}</p>
            <p class="mt-2 text-xs text-zinc-500">
              {c.data.held_descriptive.length} descriptive ·{" "}
              {c.data.held_normative.length} normative · {c.data.agents.length}{" "}
              agents
            </p>
          </a>
        </li>
      ))
    }
  </ul>
</Base>
