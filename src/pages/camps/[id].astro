---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import NodeRef from "../../components/NodeRef.astro";
import {
  analysesReferencing,
  blindspotsForCamp,
  bridgesFromCamp,
  bridgesToCamp,
  campEmoji,
  convergencesForCamp,
} from "../../lib/graph";

export async function getStaticPaths() {
  const camps = await getCollection("camps");
  return camps.map((c) => ({ params: { id: c.id }, props: { camp: c } }));
}

type Camp = Awaited<ReturnType<typeof getCollection<"camps">>>[number];
interface Props {
  camp: Camp;
}

const { camp } = Astro.props as Props;
const referencedBy = analysesReferencing(camp.id);
const bridgesOut = await bridgesFromCamp(camp.id);
const bridgesIn = await bridgesToCamp(camp.id);
const convergencesOn = await convergencesForCamp(camp.id);
const blindspotsHere = await blindspotsForCamp(camp.id);
---

<Base title={`${campEmoji(camp.id)} ${camp.data.name} --- camp`}>
  <p class="mb-2 text-xs text-zinc-500">
    <a href="/camps/" class="hover:text-zinc-300">← all camps</a>
  </p>
  <h1 class="mb-1 text-2xl text-zinc-100">
    {campEmoji(camp.id)}
    {camp.data.name}
  </h1>
  <p class="mb-8 font-mono text-xs text-zinc-500">{camp.data.id}</p>

  {
    camp.data.summary && (
      <p class="mb-8 text-sm text-zinc-300">{camp.data.summary}</p>
    )
  }

  {
    camp.data.agents.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">Agents</h2>
        <ul class="space-y-1 text-sm text-zinc-300">
          {camp.data.agents.map((a) => (
            <li>· {a}</li>
          ))}
        </ul>
      </section>
    )
  }

  {
    camp.data.held_descriptive.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Descriptive claims held ({camp.data.held_descriptive.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {camp.data.held_descriptive.map((ref) => (
            <li>
              <NodeRef id={ref.id} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    camp.data.held_normative.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Normative claims held ({camp.data.held_normative.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {camp.data.held_normative.map((ref) => (
            <li>
              <NodeRef id={ref.id} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    camp.data.disputed_evidence.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Disputed evidence ({camp.data.disputed_evidence.length})
        </h2>
        <p class="mb-2 text-xs text-zinc-500">
          Evidence this camp rejects on provenance grounds while still holding
          the underlying claim.
        </p>
        <ul class="space-y-1 text-sm">
          {camp.data.disputed_evidence.map((ref) => (
            <li class="font-mono text-xs text-zinc-500">{ref.id}</li>
          ))}
        </ul>
      </section>
    )
  }

  {
    bridgesOut.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Bridges from this camp ({bridgesOut.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {bridgesOut.map((b) => (
            <li>
              <NodeRef id={b.id} /> → <NodeRef id={b.data.to_camp.id} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    bridgesIn.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Bridges into this camp ({bridgesIn.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {bridgesIn.map((b) => (
            <li>
              <NodeRef id={b.data.from_camp.id} /> → <NodeRef id={b.id} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    convergencesOn.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Convergences involving this camp ({convergencesOn.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {convergencesOn.map((c) => (
            <li>
              <NodeRef id={c.id} /> on{" "}
              <NodeRef id={c.data.intervention_id.id} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    blindspotsHere.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Blindspots flagged on this camp ({blindspotsHere.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {blindspotsHere.map((b) => (
            <li>
              <NodeRef id={b.id} /> ---{" "}
              <span class="text-zinc-500">{b.data.against_prior_set}</span>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    referencedBy.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Analyses featuring this camp ({referencedBy.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {referencedBy.map(({ id }) => (
            <li>
              <a
                href={`/analyses/${id}/`}
                class="font-mono text-xs text-zinc-300 hover:text-zinc-100 hover:underline"
              >
                {id}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Base>
