---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import NodeRef from "../../components/NodeRef.astro";
import { KIND_EMOJI } from "../../lib/graph";

const bridges = await getCollection("bridges");
bridges.sort((a, b) => a.id.localeCompare(b.id));
---

<Base title="Bridges --- ai-for-less-suffering">
  <h1 class="mb-2 flex items-baseline gap-2 text-2xl text-zinc-100">
    <span
      class="inline-flex h-4 min-w-4 shrink-0 items-center justify-center self-center rounded-sm bg-cyan-950 px-1 font-mono text-[10px] font-semibold text-cyan-300"
      aria-hidden="true">BR</span
    >
    {KIND_EMOJI.bridge} Bridges
  </h1>
  <p class="mb-8 max-w-prose text-sm text-zinc-400">
    Normative translations from one camp's language into another's.
    Unidirectional. Caveats mark what does not translate. A bridge is not
    agreement --- it is a way for camp A's position to be read out in camp B's
    frame without collapsing the difference that makes them two camps.
  </p>
  <ul class="space-y-3">
    {
      bridges.map((b) => (
        <li class="rounded border border-zinc-800 p-4 hover:border-zinc-600">
          <a href={`/bridges/${b.id}/`} class="block">
            <div class="flex items-baseline justify-between">
              <h2 class="text-zinc-100">
                <NodeRef id={b.data.from_camp.id} /> →{" "}
                <NodeRef id={b.data.to_camp.id} />
              </h2>
              <span class="font-mono text-xs text-zinc-500">{b.data.id}</span>
            </div>
            <p class="mt-2 text-sm text-zinc-400">{b.data.translation}</p>
            {b.data.caveats.length > 0 && (
              <p class="mt-2 text-xs text-zinc-500">
                {b.data.caveats.length} caveat
                {b.data.caveats.length === 1 ? "" : "s"}
              </p>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</Base>
