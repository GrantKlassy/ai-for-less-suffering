---
import Base from "../layouts/Base.astro";
import GraphView from "../components/home/GraphView.astro";
import LedgerRow from "../components/home/LedgerRow.astro";
import { latestLeverageAnalysis } from "../lib/leverage-latest";
import {
  loadOperatorPositions,
  orphanedInterventions,
  unresolvedFlipRefs,
} from "../lib/positions";
import { getCollection } from "astro:content";

const latest = latestLeverageAnalysis();
const operator = await loadOperatorPositions();
const interventions = await getCollection("interventions");

// Build-time warnings --- noisy in dev, silent in prod-build logs beyond stderr.
// The engine-layer `afls validate` is the hard-fail; this is the soft surfacing.
const orphans = orphanedInterventions(
  interventions.map((i) => i.data.id),
  operator.positions,
);
if (orphans.length > 0) {
  console.warn(
    `[home] interventions missing operator position: ${orphans.join(", ")}`,
  );
}

const unresolved = unresolvedFlipRefs(operator.positions);
if (unresolved.length > 0) {
  console.warn(
    `[home] operator flip_conditions with unresolvable refs: ${unresolved
      .map((u) => `${u.interventionId}→${u.ref}`)
      .join(", ")}`,
  );
}

// Rankings already come sorted from the engine (-suffering_composite). Pair
// each with its coalition summary and the operator's stance. Missing position
// = null, rendered as an empty row rather than a crash.
const rankings = latest?.analysis.rankings ?? [];
const coalitionById = new Map(
  (latest?.analysis.coalition_analyses ?? []).map((c) => [
    c.intervention_id,
    c,
  ]),
);
---

<Base
  title="−SUFFERING EV book · ai-for-less-suffering.com"
  description="Operator position per intervention, ranked by suffering_composite. Typed reasoning, not manifesto."
>
  <section class="mb-8">
    <h1 class="mb-3 text-3xl tracking-tight text-zinc-100">
      −<span class="text-emerald-300">SUFFERING</span> EV book
    </h1>
    <p class="max-w-prose text-sm leading-relaxed text-zinc-400">
      What I'd aim AI at right now, ranked by
      <span class="font-mono text-emerald-300">suffering_composite</span> --- leverage
      times mean friction times mean suffering reduction.
      {
        latest ? (
          <span class="mt-1 block text-xs text-zinc-500">
            snapshot: {latest.analysis.generated_at}
          </span>
        ) : (
          <span class="mt-1 block text-xs text-amber-400">
            no leverage analysis yet. run{" "}
            <code class="text-zinc-300">afls query leverage</code>.
          </span>
        )
      }
    </p>
  </section>

  <section class="mb-10">
    <h2
      class="mb-2 text-xs font-semibold tracking-wide text-zinc-500 uppercase"
    >
      the graph
    </h2>
    <GraphView />
  </section>

  <section>
    <h2
      class="mb-4 text-xs font-semibold tracking-wide text-zinc-500 uppercase"
    >
      positions
    </h2>
    {
      rankings.length === 0 ? (
        <p class="text-sm text-zinc-500">
          no rankings. populate <code class="text-zinc-300">data/</code> and run{" "}
          <code class="text-zinc-300">afls query leverage</code>.
        </p>
      ) : (
        rankings.map((r, i) => (
          <LedgerRow
            rank={i + 1}
            ranking={r}
            coalition={coalitionById.get(r.intervention_id) ?? null}
            position={operator.positions[r.intervention_id] ?? null}
            analysisId={latest!.id}
          />
        ))
      )
    }
  </section>

  {
    latest && (
      <footer class="mt-12 border-t border-zinc-800 pt-4 text-xs text-zinc-500">
        method, contested claims, and ranking critique:{" "}
        <a
          href={`/analyses/${latest.id}/`}
          class="text-zinc-300 underline-offset-2 hover:underline"
        >
          {latest.id}
        </a>
      </footer>
    )
  }
</Base>
