---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const sources = await getCollection("sources");

// published_at is free-form in the schema. Observed formats:
//   'YYYY-MM-DD' | 'YYYY-MM' | 'YYYY' | 'YYYY-YYYY' | 'ongoing' | ''
// Normalize to a sortable 'YYYY-MM-DD' key; pad missing fields to end-of-period
// so year-only entries sort after month-specific entries of the same year.
// Returns null when the value can't be parsed (e.g. "ongoing", empty) --- those
// sources sink to a second bucket so dated articles rank first.
const PAD_END = { month: "12", day: "31" };
function parsePublished(published: string): string | null {
  const p = (published ?? "").trim();
  if (!p) return null;
  const iso = /^(\d{4})(?:-(\d{2}))?(?:-(\d{2}))?$/.exec(p);
  if (iso) {
    const [, y, m, d] = iso;
    return `${y}-${m ?? PAD_END.month}-${d ?? PAD_END.day}T23:59:59Z`;
  }
  const range = /^\d{4}-(\d{4})$/.exec(p);
  if (range) {
    return `${range[1]}-${PAD_END.month}-${PAD_END.day}T23:59:59Z`;
  }
  return null;
}

function displayDate(published: string): string {
  const p = (published ?? "").trim();
  return p.length > 0 ? p : "---";
}

// Two-bucket sort: dated articles first (desc by published_at), undated /
// ongoing sources after (desc by updated_at). Keeps "most recent articles at
// the top" literal --- continuously-updated datasets don't jump the queue just
// because their updated_at is fresh.
const sorted = [...sources].sort((a, b) => {
  const pa = parsePublished(a.data.published_at);
  const pb = parsePublished(b.data.published_at);
  if (pa && !pb) return -1;
  if (pb && !pa) return 1;
  if (pa && pb && pa !== pb) return pb.localeCompare(pa);
  return b.data.updated_at.localeCompare(a.data.updated_at);
});
---

<Base title="Sources --- ai-for-less-suffering">
  <h1 class="mb-2 flex items-baseline gap-2 text-2xl text-zinc-100">
    <span
      class="inline-flex h-4 min-w-4 shrink-0 items-center justify-center self-center rounded-sm bg-amber-950 px-1 font-mono text-[10px] font-semibold text-amber-300"
      aria-hidden="true">S</span
    >
    📰 Sources
  </h1>
  <p class="mb-8 text-sm text-zinc-400">
    Citable things evidence points at. Operator-scored reliability is separate
    from the claim confidence it backs --- a high-reliability source can support
    a low-confidence claim and vice versa. Most recently published at the top.
  </p>
  <ul class="space-y-2">
    {
      sorted.map((s) => (
        <li class="rounded border border-zinc-800 p-3 hover:border-zinc-600">
          <a href={`/sources/${s.id}/`} class="block text-sm text-zinc-200">
            <p class="text-zinc-100">{s.data.title}</p>
            <p class="mt-1 flex flex-wrap items-center justify-between gap-x-3 gap-y-1 text-xs">
              <span class="font-mono text-zinc-500">{s.data.id}</span>
              <span class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <span class="font-mono tracking-wide text-amber-300 uppercase">
                  {s.data.source_kind.replace(/_/g, " ")}
                </span>
                <span class="font-mono text-zinc-500">
                  {displayDate(s.data.published_at)}
                </span>
                <span class="text-zinc-500">
                  reliability {s.data.reliability.toFixed(2)}
                </span>
              </span>
            </p>
          </a>
        </li>
      ))
    }
  </ul>
</Base>
