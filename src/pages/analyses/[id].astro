---
// Dispatcher on analysis.kind. Each kind renders through its own *View
// component under src/components/analyses/. Contested claims render the same
// way across every kind, so they live here.

import Base from "../../layouts/Base.astro";
import SteelmanView from "../../components/analyses/SteelmanView.astro";
import PalantirView from "../../components/analyses/PalantirView.astro";
import LeverageView from "../../components/analyses/LeverageView.astro";
import ContestedTrack from "../../components/analyses/ContestedTrack.astro";
import { allAnalyses, ANALYSIS_EMOJI } from "../../lib/graph";
import type { Analysis } from "../../lib/analysis";

export async function getStaticPaths() {
  return allAnalyses().map(({ id, analysis }) => ({
    params: { id },
    props: { analysis },
  }));
}

interface Props {
  analysis: Analysis;
}

const { analysis } = Astro.props;

const titleByKind: Record<Analysis["kind"], string> = {
  palantir: `Palantir analysis --- ${analysis.generated_at}`,
  leverage: `Leverage analysis --- ${analysis.generated_at}`,
  steelman: `Steelman analysis --- ${analysis.generated_at}`,
};
const headingByKind: Record<Analysis["kind"], string> = {
  palantir: "Palantir coalition analysis",
  leverage: "Leverage analysis",
  steelman: "Steelman analysis",
};
---

<Base title={titleByKind[analysis.kind]}>
  <h1 class="mb-2 text-2xl text-zinc-100">
    {ANALYSIS_EMOJI}
    {headingByKind[analysis.kind]}
  </h1>
  <p class="mb-8 text-xs text-zinc-500">
    Generated <span class="font-mono">{analysis.generated_at}</span>
  </p>

  {analysis.kind === "steelman" && <SteelmanView analysis={analysis} />}
  {analysis.kind === "palantir" && <PalantirView analysis={analysis} />}
  {analysis.kind === "leverage" && <LeverageView analysis={analysis} />}

  <ContestedTrack claims={analysis.contested_claims} />
</Base>
