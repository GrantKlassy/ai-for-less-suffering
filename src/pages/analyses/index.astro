---
import fs from "node:fs";
import path from "node:path";
import Base from "../../layouts/Base.astro";
import { parseAnalysis, type AnalysisEntry } from "../../lib/analysis";

function loadAnalyses(): AnalysisEntry[] {
  const analysesDir = path.resolve(process.cwd(), "public-output/analyses");
  if (!fs.existsSync(analysesDir)) return [];
  return fs
    .readdirSync(analysesDir)
    .filter((name) => name.endsWith(".json"))
    .map((name): AnalysisEntry => {
      const id = name.replace(/\.json$/, "");
      const raw = fs.readFileSync(path.join(analysesDir, name), "utf-8");
      return { id, analysis: parseAnalysis(name, raw) };
    })
    .sort((a, b) =>
      b.analysis.generated_at.localeCompare(a.analysis.generated_at),
    );
}

const entries = loadAnalyses();
---

<Base title="Analyses --- ai-for-less-suffering">
  <h1 class="mb-2 text-2xl text-zinc-100">Analyses</h1>
  <p class="mb-8 text-sm text-zinc-400">
    Structured outputs from the afls reasoning engine. Each analysis is
    descriptive convergence + normative divergence + coalition bridges, written
    to canonical JSON and shaped prose.
  </p>

  {
    entries.length === 0 ? (
      <div class="rounded border border-zinc-800 p-6 text-sm text-zinc-400">
        <p>No analyses yet.</p>
        <p class="mt-2">
          Run <code class="text-zinc-200">afls query palantir</code> to generate
          the first one.
        </p>
      </div>
    ) : (
      <ul class="space-y-3">
        {entries.map(({ id, analysis }) => (
          <li class="rounded border border-zinc-800 p-4 hover:border-zinc-600">
            <a href={`/analyses/${id}/`} class="block">
              <div class="flex justify-between text-sm">
                <span class="text-zinc-100">{id}</span>
                <span class="text-zinc-500">{analysis.generated_at}</span>
              </div>
              <div class="mt-2 text-xs text-zinc-500">
                {analysis.kind === "palantir" ? (
                  <>
                    camps: {analysis.camps.join(", ")} · bridges:{" "}
                    {analysis.bridges.length} · blindspots:{" "}
                    {analysis.blindspots.length} · contested:{" "}
                    {analysis.contested_claims.length}
                  </>
                ) : (
                  <>
                    camps: {analysis.camps.join(", ")} · ranked:{" "}
                    {analysis.rankings.length} · ranking blindspots:{" "}
                    {analysis.ranking_blindspots.length} · contested:{" "}
                    {analysis.contested_claims.length}
                  </>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</Base>
