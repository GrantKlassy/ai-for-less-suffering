---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import { interventionsScoringFriction } from "../../../lib/graph";

export async function getStaticPaths() {
  const layers = await getCollection("frictionLayers");
  return layers.map((l) => ({ params: { id: l.id }, props: { layer: l } }));
}

type Layer = Awaited<
  ReturnType<typeof getCollection<"frictionLayers">>
>[number];
interface Props {
  layer: Layer;
}

const { layer } = Astro.props as Props;
const interventions = await interventionsScoringFriction(layer.id);
---

<Base title={`${layer.data.name} --- friction layer`}>
  <p class="mb-2 text-xs text-zinc-500">
    <a href="/layers/" class="hover:text-zinc-300">← all layers</a>
  </p>
  <p class="mb-2 font-mono text-xs text-orange-400">friction layer</p>
  <h1 class="mb-2 text-2xl text-zinc-100">{layer.data.name}</h1>
  <p class="mb-6 font-mono text-xs text-zinc-500">{layer.data.id}</p>

  <p class="mb-8 text-sm text-zinc-300">{layer.data.description}</p>

  {
    interventions.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-3 text-sm text-zinc-400">
          Interventions scored against this layer
        </h2>
        <ul class="space-y-2">
          {interventions.map((i) => {
            const score = i.data.friction_scores[layer.id] ?? 0;
            const pct = Math.max(0, Math.min(1, score)) * 100;
            return (
              <li class="rounded border border-zinc-800 p-3 text-xs">
                <div class="mb-1 flex items-baseline justify-between">
                  <a
                    href={`/interventions/${i.id}/`}
                    class="text-sm text-emerald-300 hover:text-emerald-200 hover:underline"
                  >
                    {i.data.text}
                  </a>
                  <span class="ml-3 shrink-0 font-mono text-zinc-400">
                    {score.toFixed(2)}
                  </span>
                </div>
                <div class="relative h-1.5 overflow-hidden rounded-full bg-zinc-900">
                  <div
                    class="absolute inset-y-0 left-0 bg-gradient-to-r from-orange-800 via-amber-600 to-emerald-500"
                    style={`width: ${pct}%`}
                  />
                </div>
              </li>
            );
          })}
        </ul>
      </section>
    )
  }
</Base>
