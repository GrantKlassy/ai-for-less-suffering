---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const friction = (await getCollection("frictionLayers")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
const harm = (await getCollection("harmLayers")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
const suffering = (await getCollection("sufferingLayers")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
---

<Base title="Layers --- ai-for-less-suffering">
  <h1 class="mb-2 text-2xl text-zinc-100">Layers</h1>
  <p class="mb-8 text-sm text-zinc-400">
    Friction slows an intervention (grid, capex, regulation). Harm is what the
    intervention costs <em>when it lands</em> (water, extraction, displacement, concentration,
    lock-in). Suffering is what it <em>relieves</em> --- the numerator in −suffering
    EV, disjoint from harm so the direction of the score is not smuggled into a cost
    axis. Polarity is shared: 1 = best outcome (no friction · no harm · maximum reduction),
    0 = worst.
  </p>

  <section class="mb-10">
    <h2 class="mb-4 text-lg text-orange-300">Friction ({friction.length})</h2>
    <ul class="space-y-2">
      {
        friction.map((l) => (
          <li class="rounded border border-zinc-800 p-3 hover:border-zinc-600">
            <a
              href={`/layers/friction/${l.id}/`}
              class="block text-sm text-zinc-200"
            >
              <div class="flex items-baseline justify-between">
                <p class="text-zinc-100">{l.data.name}</p>
                <span class="font-mono text-xs text-zinc-500">{l.data.id}</span>
              </div>
              <p class="mt-1 text-xs text-zinc-400">{l.data.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mb-10">
    <h2 class="mb-4 text-lg text-rose-300">Harm ({harm.length})</h2>
    <ul class="space-y-2">
      {
        harm.map((l) => (
          <li class="rounded border border-zinc-800 p-3 hover:border-zinc-600">
            <a
              href={`/layers/harm/${l.id}/`}
              class="block text-sm text-zinc-200"
            >
              <div class="flex items-baseline justify-between">
                <p class="text-zinc-100">{l.data.name}</p>
                <span class="font-mono text-xs text-zinc-500">{l.data.id}</span>
              </div>
              <p class="mt-1 text-xs text-zinc-400">{l.data.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mb-10">
    <h2 class="mb-4 text-lg text-emerald-300">
      Suffering ({suffering.length})
    </h2>
    <ul class="space-y-2">
      {
        suffering.map((l) => (
          <li class="rounded border border-zinc-800 p-3 hover:border-zinc-600">
            <a
              href={`/layers/suffering/${l.id}/`}
              class="block text-sm text-zinc-200"
            >
              <div class="flex items-baseline justify-between">
                <p class="text-zinc-100">{l.data.name}</p>
                <span class="font-mono text-xs text-zinc-500">{l.data.id}</span>
              </div>
              <p class="mt-1 text-xs text-zinc-400">{l.data.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
