---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import NodeRef from "../../components/NodeRef.astro";
import { analysesReferencing, KIND_EMOJI } from "../../lib/graph";

export async function getStaticPaths() {
  const convergences = await getCollection("convergences");
  return convergences.map((c) => ({
    params: { id: c.id },
    props: { convergence: c },
  }));
}

type Convergence = Awaited<
  ReturnType<typeof getCollection<"convergences">>
>[number];
interface Props {
  convergence: Convergence;
}

const { convergence } = Astro.props as Props;
const referencedBy = analysesReferencing(convergence.id);
const reasonEntries = Object.entries(convergence.data.divergent_reasons);
---

<Base
  title={`${KIND_EMOJI.convergence} ${convergence.data.id} --- convergence`}
>
  <p class="mb-2 text-xs text-zinc-500">
    <a href="/convergences/" class="hover:text-zinc-300">← all convergences</a>
  </p>
  <h1 class="mb-1 text-2xl text-zinc-100">
    {KIND_EMOJI.convergence}
    <NodeRef id={convergence.data.intervention_id.id} />
  </h1>
  <p class="mb-8 font-mono text-xs text-zinc-500">{convergence.data.id}</p>

  <section class="mb-8">
    <h2 class="mb-2 text-sm text-zinc-400">
      Converging camps ({convergence.data.camps.length})
    </h2>
    <ul class="space-y-1 text-sm">
      {
        convergence.data.camps.map((ref) => (
          <li>
            <NodeRef id={ref.id} />
          </li>
        ))
      }
    </ul>
  </section>

  {
    reasonEntries.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Divergent reasons ({reasonEntries.length})
        </h2>
        <p class="mb-2 text-xs text-zinc-500">
          Each camp's route to this intervention is a different normative claim.
          Same destination; different premises.
        </p>
        <ul class="space-y-2 text-sm">
          {reasonEntries.map(([campId, normId]) => (
            <li class="flex flex-wrap items-baseline gap-2">
              <NodeRef id={campId} />
              <span class="text-zinc-500">via</span>
              <NodeRef id={normId} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    referencedBy.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm text-zinc-400">
          Analyses featuring this convergence ({referencedBy.length})
        </h2>
        <ul class="space-y-1 text-sm">
          {referencedBy.map(({ id }) => (
            <li>
              <a
                href={`/analyses/${id}/`}
                class="font-mono text-xs text-zinc-300 hover:text-zinc-100 hover:underline"
              >
                {id}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Base>
