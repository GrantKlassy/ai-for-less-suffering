---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import NodeRef from "../../components/NodeRef.astro";
import { KIND_EMOJI } from "../../lib/graph";

const convergences = await getCollection("convergences");
convergences.sort((a, b) => a.id.localeCompare(b.id));
---

<Base title="Convergences --- ai-for-less-suffering">
  <h1 class="mb-2 flex items-baseline gap-2 text-2xl text-zinc-100">
    <span
      class="inline-flex h-4 min-w-4 shrink-0 items-center justify-center self-center rounded-sm bg-lime-950 px-1 font-mono text-[10px] font-semibold text-lime-300"
      aria-hidden="true">CV</span
    >
    {KIND_EMOJI.convergence} Convergences
  </h1>
  <p class="mb-8 max-w-prose text-sm text-zinc-400">
    Coalition logic as data. Multiple camps arriving at the same intervention
    for different normative reasons. The point is not that the camps agree ---
    it is that the intervention does not require them to.
  </p>
  <ul class="space-y-3">
    {
      convergences.map((c) => (
        <li class="rounded border border-zinc-800 p-4 hover:border-zinc-600">
          <a href={`/convergences/${c.id}/`} class="block">
            <div class="flex items-baseline justify-between">
              <h2 class="text-zinc-100">
                <NodeRef id={c.data.intervention_id.id} />
              </h2>
              <span class="font-mono text-xs text-zinc-500">{c.data.id}</span>
            </div>
            <p class="mt-2 text-xs text-zinc-500">
              {c.data.camps.length} camps converging
            </p>
          </a>
        </li>
      ))
    }
  </ul>
</Base>
